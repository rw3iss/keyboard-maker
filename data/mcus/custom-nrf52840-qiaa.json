  "designNotes": [
    "ADVANCED -- requires significant PCB design experience",
    "QFN-73 package with 0.4mm pitch -- needs 4-layer PCB minimum",
    "48 GPIOs available -- maximum flexibility for matrix, LEDs, and peripherals",
    "Requires external 32MHz crystal for USB, 32.768kHz crystal for BLE",
    "Antenna design is critical -- PCB trace antenna requires careful impedance matching",
    "DCC/DCCH inductor/capacitor values are critical for power supply stability",
    "Reference design available in Nordic nRF52840-DK schematics",
    "USB D+/D- need series 27 ohm resistors",
    "Needs custom ZMK/Zephyr board definition",
    "Most cost-effective per-unit at scale, but highest NRE cost",
    "Consider Holyiot 18010 module for simpler integration with similar capability"
  ],
  "features": [
    "48 GPIOs — maximum flexibility for any keyboard layout",
    "Full nRF52840 with USB, BLE 5.0, NFC",
    "1MB flash, 256KB RAM, 64MHz ARM Cortex-M4F",
    "Lowest per-unit cost at scale",
    "8 analog inputs (ADC channels)",
    "Direct hardware access to all peripherals"
  ],
  "concerns": [
    "Requires significant PCB design experience",
    "QFN-73 with 0.4mm pitch — needs 4-layer PCB minimum",
    "Must design antenna matching network",
    "Requires external 32MHz and 32.768kHz crystals",
    "Many decoupling capacitors and power supply components needed",
    "Needs SWD programmer (J-Link) for initial bootloader flash",
    "Highest NRE cost despite lowest per-unit cost"
  ],
